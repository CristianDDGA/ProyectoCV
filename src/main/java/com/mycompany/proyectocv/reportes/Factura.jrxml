	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Param_NumeroFactura" class="java.lang.String"/>
	<parameter name="Param_Logo" class="java.io.InputStream"/>
	<queryString>
		<![CDATA[SELECT 
    f.numero_factura, 
    f.fecha, 
    u.usuario AS cajero, 
    c.nombre AS cliente_nombre, 
    c.apellido AS cliente_apellido,
    c.cedula_ruc,
    c.direccion,
    f.subtotal AS subtotal_factura,
    f.iva,
    f.total AS total_general,
    d.cantidad, 
    d.precio_unitario, 
    d.subtotal AS subtotal_item,
    p.nombre AS nombre_producto, 
    p.codigo AS codigo_producto
FROM facturas f
INNER JOIN usuarios u ON f.id_usuario = u.id_usuario
INNER JOIN clientes c ON f.id_cliente = c.id_cliente
INNER JOIN detalles_factura d ON f.id_factura = d.id_factura
INNER JOIN productos p ON d.id_producto = p.id_producto
WHERE f.numero_factura = $P{Param_NumeroFactura}]]>
	</queryString>
	<field name="numero_factura" class="java.lang.String"/>
	<field name="fecha" class="java.sql.Timestamp"/>
	<field name="cajero" class="java.lang.String"/>
	<field name="cliente_nombre" class="java.lang.String"/>
	<field name="cliente_apellido" class="java.lang.String"/>
	<field name="cedula_ruc" class="java.lang.String"/>
	<field name="direccion" class="java.lang.String"/>
	<field name="subtotal_factura" class="java.math.BigDecimal"/>
